{
  "name": "tracer-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "TEMPO_URL=${TEMPO_URL:-localhost:3200} PORT=7777 bun run --watch server/index.ts",
