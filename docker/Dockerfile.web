# Build context is the repository root. Bake resolves the `context = "."` in
# docker-bake.hcl against the caller's cwd, so the build must be invoked from
# the repo root (as `just build` does).
ARG BUN_VERSION=1

FROM oven/bun:${BUN_VERSION} AS build

WORKDIR /app

# Install dependencies first so they cache independently of source changes.
COPY web/package.json web/bun.lock ./
RUN bun install --frozen-lockfile

COPY web/ ./
RUN bun run build

# Runtime: one Bun process serves the SPA, the /api/v1 REST API, and the
# GET-only /tempo passthrough on port 8080. The server has zero runtime
# dependencies — only the lib sources and the built dist ride along. It
# fails fast with a clear message when TEMPO_URL is unset (the contract
# entrypoint.sh used to enforce for Caddy).
FROM oven/bun:${BUN_VERSION}-slim

WORKDIR /app
COPY --from=build /app/dist ./dist
COPY web/server ./server
COPY web/src/lib ./src/lib
COPY web/src/api ./src/api
COPY web/package.json ./package.json

ENV PORT=8080
EXPOSE 8080
USER bun

# Liveness only (/api/v1 is static) — Tempo reachability is /api/v1/health.
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s \
  CMD ["bun", "-e", "const r = await fetch('http://localhost:8080/api/v1'); if (!r.ok) process.exit(1)"]

ENTRYPOINT ["bun", "server/index.ts"]
